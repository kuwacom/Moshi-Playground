# 利用するLoRA名
LORA_NAME=moshi-lora

# dataset配下のルートディレクトリ
DATASET_ROOT=datasets

# 元音声を置くディレクトリ
DATASET_RAW_DIR=${DATASET_ROOT}/raw/${LORA_NAME}

# 学習用stereo wavを置くディレクトリ
DATASET_STEREO_DIR=${DATASET_ROOT}/stereo/${LORA_NAME}

# Whisper、LLM、TTSの途中結果を置くディレクトリ
DATASET_CACHE_DIR=${DATASET_ROOT}/cache/${LORA_NAME}

# TTS単体確認用の音声を置くディレクトリ
DATASET_TTS_DIR=${DATASET_ROOT}/tts/${LORA_NAME}

# 学習に使うJSONL
TRAIN_JSONL=${DATASET_ROOT}/${LORA_NAME}.jsonl

# 学習結果を保存するディレクトリ
RUN_DIR=loras/${LORA_NAME}

# 最新checkpointから推論用LoRAを書き出すディレクトリ
LORA_LATEST_DIR=${RUN_DIR}/latest

# 管理対象にする学習configの雛形
TRAIN_CONFIG_TEMPLATE_PATH=config/llmJpMoshiLora.example.yaml

# train-run.shが生成するLoRA別の学習config
TRAIN_CONFIG_PATH=config/${LORA_NAME}.yaml

# ベースにするHugging Face repo
HF_REPO=llm-jp/llm-jp-moshi-v1

# 利用するGPU ID
CUDA_VISIBLE_DEVICES=0

# torchrunで起動するプロセス数
# autoの場合はCUDA_VISIBLE_DEVICESの数に合わせる
NPROC_PER_NODE=auto

# torchrunの分散通信用ポート
MASTER_PORT=29501

# torch compileを無効化するかどうか
NO_TORCH_COMPILE=1

# OpenAI互換APIのベースURL
OPENAI_BASE_URL=

# OpenAI互換APIのAPIキー
OPENAI_API_KEY=

# OpenAI互換APIで使うモデル名
OPENAI_MODEL=anthropic/claude-sonnet-4.6

# Kuwa TTS APIのURL
KUWA_TTS_URL=

# Kuwa TTS APIの話者タイプ
KUWA_TTS_TYPE=10
